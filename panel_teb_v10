<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panel TEB — v5</title>
<script src="https://unpkg.com/@supabase/supabase-js@2"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
body{background:#f5f5f0;color:#1a1a1a}
.topbar{background:#004225;color:white;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.topbar h1{font-size:16px;font-weight:500}
.topbar-links{display:flex;gap:10px}
.topbar-links a{color:white;font-size:12px;opacity:.8;text-decoration:none;padding:5px 10px;border:0.5px solid rgba(255,255,255,.3);border-radius:6px}
.topbar-links a:hover{opacity:1;background:rgba(255,255,255,.1)}
.container{max-width:1300px;margin:0 auto;padding:24px}
.metrics{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-bottom:20px}
.metric{background:white;border-radius:10px;padding:14px 16px;border:0.5px solid #e0e0d8}
.metric-label{font-size:11px;color:#888;margin-bottom:5px}
.metric-value{font-size:22px;font-weight:500}
.green{color:#27500A}.red{color:#791F1F}.amber{color:#633806}.blue{color:#0C447C}
.card{background:white;border-radius:10px;border:0.5px solid #e0e0d8;margin-bottom:20px}
.card-header{padding:14px 20px;border-bottom:0.5px solid #e0e0d8;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.card-header h2{font-size:14px;font-weight:500}
.filters{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
select,input[type=text],input[type=number],input[type=date],textarea{padding:7px 10px;border:0.5px solid #d0d0c8;border-radius:6px;font-size:13px;background:white;color:#1a1a1a;outline:none}
select:focus,input:focus,textarea:focus{border-color:#004225}
table{width:100%;border-collapse:collapse;font-size:12.5px}
th{background:#f8f8f5;padding:9px 12px;text-align:left;font-size:11px;font-weight:500;color:#666;border-bottom:0.5px solid #e0e0d8;white-space:nowrap}
td{padding:9px 12px;border-bottom:0.5px solid #f0f0e8;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:#fafaf7}
tr.row-warn td{background:#FAEEDA18}
tr.row-danger td{background:#FCEBEB22}
.pill{display:inline-flex;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:500}
.pill-green{background:#EAF3DE;color:#27500A}
.pill-red{background:#FCEBEB;color:#791F1F}
.pill-amber{background:#FAEEDA;color:#633806}
.pill-blue{background:#E6F1FB;color:#0C447C}
.pill-gray{background:#F1EFE8;color:#444}
.pill-purple{background:#EEEDFE;color:#3C3489}
.progress{display:flex;align-items:center;gap:6px}
.progress-bar{height:5px;background:#e0e0d8;border-radius:99px;width:70px;overflow:hidden}
.progress-fill{height:100%;border-radius:99px}
.btn{padding:7px 14px;border-radius:6px;font-size:13px;cursor:pointer;border:0.5px solid #d0d0c8;background:white;color:#1a1a1a}
.btn:hover{background:#f5f5f0}
.btn-primary{background:#004225;color:white;border-color:#004225}
.btn-primary:hover{background:#003018}
.btn-danger{background:#FCEBEB;color:#791F1F;border-color:#F7C1C1}
.btn-danger:hover{background:#F7C1C1}
.btn-sm{padding:4px 10px;font-size:12px}
.tab-bar{display:flex;gap:4px;margin-bottom:20px;flex-wrap:wrap}
.tab{padding:8px 16px;border-radius:6px;font-size:13px;cursor:pointer;border:0.5px solid #d0d0c8;background:white;color:#666}
.tab.active{background:#004225;color:white;border-color:#004225}
.nombre-link{color:#004225;cursor:pointer;font-weight:500}
.nombre-link:hover{text-decoration:underline}
.wa-link{color:#25D366;font-size:12px;text-decoration:none}
.loading{text-align:center;padding:30px;color:#888;font-size:14px}
.alert{padding:10px 14px;border-radius:6px;font-size:13px;margin-bottom:12px}
.alert-success{background:#EAF3DE;color:#27500A}
.alert-error{background:#FCEBEB;color:#791F1F}
.alert-info{background:#E6F1FB;color:#0C447C}
.dias-ok{color:#27500A;font-size:12px}
.dias-warn{color:#633806;font-weight:500;font-size:12px}
.dias-danger{color:#791F1F;font-weight:600;font-size:12px}

/* Modal principal */
.modal-overlay{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.45);z-index:100;align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto}
.modal-overlay.open{display:flex}
.modal{background:white;border-radius:14px;width:760px;max-width:100%;margin-bottom:40px}
.modal-header{padding:18px 24px;border-bottom:0.5px solid #e0e0d8;display:flex;align-items:flex-start;justify-content:space-between;gap:12px}
.modal-header h3{font-size:16px;font-weight:500}
.modal-header .sub{font-size:12px;color:#888;margin-top:3px}
.modal-tabs{display:flex;padding:0 24px;border-bottom:0.5px solid #e0e0d8;overflow-x:auto}
.modal-tab{padding:10px 16px;font-size:13px;cursor:pointer;border:none;background:none;color:#666;border-bottom:2px solid transparent;margin-bottom:-1px;white-space:nowrap}
.modal-tab.active{color:#004225;font-weight:500;border-bottom:2px solid #004225}
.modal-body{padding:20px 24px;max-height:60vh;overflow-y:auto;max-height:62vh;overflow-y:auto}
.modal-footer{display:flex;justify-content:flex-end;gap:8px;padding:14px 24px;border-top:0.5px solid #e0e0d8}

/* Perfil */
.section-block{margin-bottom:18px}
.section-title{font-size:11px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-row-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.form-group{margin-bottom:10px}
.form-group label{display:block;font-size:11px;color:#666;margin-bottom:3px;font-weight:500}
.form-group input,.form-group select,.form-group textarea{width:100%;padding:7px 10px;border:0.5px solid #d0d0c8;border-radius:6px;font-size:13px}
.form-group textarea{resize:vertical}
.fin-box{background:#f8f8f5;border-radius:10px;padding:14px;margin-bottom:14px}
.fin-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.fin-grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.fin-item label{font-size:11px;color:#888;display:block;margin-bottom:2px}
.fin-item span{font-size:16px;font-weight:500}
.fin-divider{border:none;border-top:0.5px solid #e0e0d8;margin:10px 0}

/* Pagos editable */
.pago-card{border:0.5px solid #e0e0d8;border-radius:8px;margin-bottom:10px;overflow:hidden}
.pago-card-header{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:#f8f8f5;cursor:pointer;gap:8px}
.pago-card-header:hover{background:#f0f0e8}
.pago-card-body{display:none;padding:14px;border-top:0.5px solid #e0e0d8}
.pago-card-body.open{display:block}
.pago-badge{display:flex;align-items:center;gap:8px}
.add-pago-form{background:#EAF3DE22;border:0.5px solid #C0DD97;border-radius:8px;padding:14px;margin-top:12px}
.add-pago-title{font-size:12px;font-weight:600;color:#27500A;margin-bottom:12px;text-transform:uppercase;letter-spacing:.04em}

/* Comentarios */
.comentario-item{border-left:3px solid #EF9F27;padding:10px 12px;margin-bottom:10px;background:#FAEEDA22;border-radius:0 6px 6px 0}
.comentario-fecha{font-size:11px;color:#854F0B;margin-bottom:3px}
.comentario-texto{font-size:13px;color:#1a1a1a;line-height:1.5}
.comentario-autor{font-size:11px;color:#854F0B;margin-top:3px;text-align:right}
.comentario-add{background:#f8f8f5;border-radius:8px;padding:14px;margin-top:12px}
.comentario-add textarea{width:100%;padding:8px;border:0.5px solid #d0d0c8;border-radius:6px;font-size:13px;height:70px;resize:vertical;margin-bottom:8px}

/* Estado cuenta */
.cuenta-header{background:#004225;color:white;padding:20px 24px;border-radius:10px 10px 0 0}
.cuenta-body{padding:20px 24px}
.cuenta-section{margin-bottom:20px}
.cuenta-section h4{font-size:12px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;border-bottom:0.5px solid #e0e0d8;padding-bottom:6px}
.cuenta-row{display:flex;justify-content:space-between;font-size:13px;padding:5px 0;border-bottom:0.5px solid #f5f5f0}
.cuenta-row:last-child{border-bottom:none}
.cuenta-row.total{font-weight:600;font-size:14px;padding-top:8px;border-top:1px solid #e0e0d8;margin-top:4px}
.cuenta-pago{display:grid;grid-template-columns:auto 1fr auto auto;gap:12px;padding:7px 0;border-bottom:0.5px solid #f5f5f0;font-size:13px;align-items:center}
.cuenta-pago:last-child{border-bottom:none}

/* Dashboard */
.ed-card{background:white;border-radius:10px;border:0.5px solid #e0e0d8;padding:16px;margin-bottom:12px}
.ed-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px}
.ed-stat{text-align:center;padding:10px;background:#f8f8f5;border-radius:8px}
.ed-stat-val{font-size:18px;font-weight:500}
.ed-stat-lbl{font-size:11px;color:#888;margin-top:2px}
.prog-bar-big{height:8px;background:#e0e0d8;border-radius:99px;overflow:hidden;margin-bottom:4px}
.prog-bar-big-fill{height:100%;border-radius:99px;background:#004225}
.alerta-row{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-radius:6px;margin-bottom:4px;font-size:12px}
.alerta-danger{background:#FCEBEB;border-left:3px solid #E24B4A}
.alerta-warn{background:#FAEEDA;border-left:3px solid #EF9F27}
</style>
</head>
