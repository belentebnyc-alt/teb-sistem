function alertasVisa(){
  const hoy=new Date();hoy.setHours(0,0,0,0);
  return ALL.filter(a=>{
    if(!a.visa_fecha_cita||a.visa==='SI')return false;
    const cita=new Date(a.visa_fecha_cita);
    const dias=Math.ceil((cita-hoy)/(864e5));
    return dias>=0&&dias<=20;
  }).sort((a,b)=>new Date(a.visa_fecha_cita)-new Date(b.visa_fecha_cita));
}

