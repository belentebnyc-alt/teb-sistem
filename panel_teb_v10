      visa_asesor:gv('e-visa-asesor')||null,
      visa_fecha_cita:gv('e-visa-fecha')||null
    };
    // Limpiar nulls de campos que no existen en el DOM
    Object.keys(updates).forEach(k=>{if(updates[k]===null&&k!=='edicion_id'&&k!=='visa_asesor'&&k!=='visa_fecha_cita'&&k!=='doc_reprogramacion')delete updates[k];});
