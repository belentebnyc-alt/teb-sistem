function copiarLink(alumnoId){
  const base=window.location.href.split('panel_teb_v5.html')[0];
  const link=base+'portal_alumno_v2.html?id='+alumnoId;
  function hacerCopia(){
    const ta=document.createElement('textarea');
    ta.value=link;ta.style.cssText='position:fixed;left:-9999px;top:0';
    document.body.appendChild(ta);ta.focus();ta.select();
    try{document.execCommand('copy');mostrarOk();}catch(e){mostrarDialog(link);}
    document.body.removeChild(ta);
  }
  if(navigator.clipboard&&window.isSecureContext){
    navigator.clipboard.writeText(link).then(mostrarOk).catch(()=>hacerCopia());
  } else {
    hacerCopia();
  }
}
function mostrarOk(){
  const m=document.createElement('div');
  m.style.cssText='position:fixed;top:20px;right:20px;background:#004225;color:white;padding:12px 20px;border-radius:8px;font-size:13px;z-index:9999;box-shadow:0 4px 16px rgba(0,0,0,.3)';
  m.textContent='\u2713 Link copiado. Mand\u00e1selo al alumno por WhatsApp.';
  document.body.appendChild(m);setTimeout(()=>m.remove(),3500);
}
function mostrarDialog(link){
  const o=document.createElement('div');
