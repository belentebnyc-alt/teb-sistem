async function subirContrato(tipo, inputId){
  const input = document.getElementById(inputId);
  const file = input.files[0];
  if(!file||!alumno)return;
  if(file.type!=='application/pdf'){alert('Solo se aceptan archivos PDF.');return;}
  if(file.size>5*1024*1024){alert('El archivo no puede superar 5MB.');return;}

  const alertEl=document.getElementById('modal-alert');
  alertEl.innerHTML='<div class="alert alert-info">Subiendo PDF...</div>';

  const fileName=tipo+'_'+alumno.id+'_'+Date.now()+'.pdf';
  const {data,error}=await db.storage.from('contratos').upload(fileName,file,{upsert:true});

  if(error){alertEl.innerHTML='<div class="alert alert-error">Error al subir: '+error.message+'</div>';return;}

  const {data:urlData}=db.storage.from('contratos').getPublicUrl(fileName);
  const url=urlData.publicUrl;

  const campo=tipo==='contrato'?'contrato_url':'reprog_url';
  const {error:e2}=await db.from('alumnos').update({[campo]:url}).eq('id',alumno.id);
  if(e2){alertEl.innerHTML='<div class="alert alert-error">Error al guardar URL: '+e2.message+'</div>';return;}

  alumno[campo]=url;
  ALL.find(a=>a.id===alumno.id)[campo]=url;
  alertEl.innerHTML='<div class="alert alert-success">✓ PDF subido correctamente. El alumno ya puede verlo en su portal.</div>';
  setTimeout(()=>alertEl.innerHTML='',3000);
  input.value='';
  mTab(tabM);
}

