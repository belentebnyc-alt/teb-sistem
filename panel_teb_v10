async function guardarNuevoPago(){
  const fecha=document.getElementById('np-fecha').value;
  const montoUSD=parseFloat(document.getElementById('np-monto-usd').value)||0;
  const montoARS=parseFloat(document.getElementById('np-monto-ars').value)||0;
  const tc=parseFloat(document.getElementById('np-tc').value)||0;
  const metodo=document.getElementById('np-metodo').value;
  const cuota=parseInt(document.getElementById('np-cuota').value)||null;
  const quien=document.getElementById('np-quien').value;
  const notas=document.getElementById('np-notas').value;
  const alertEl=document.getElementById('modal-alert');

  if(!fecha||(!montoUSD&&!montoARS)){alertEl.innerHTML='<div class="alert alert-error">Completá fecha y monto.</div>';return;}

  const montoARSenUSD=tc>0?montoARS/tc:0;
  const montoTotal=montoUSD+montoARSenUSD;
  const notasCompletas=[notas,montoARS>0?'ARS $ '+Math.round(montoARS).toLocaleString('es-AR')+(tc>0?' (TC:'+tc+')':''):''].filter(Boolean).join(' · ')||null;

  const {error}=await db.from('pagos').insert({alumno_id:alumno.id,fecha,monto:montoTotal,metodo,cuota,quien_recibio:quien||null,notas:notasCompletas});
  if(error){alertEl.innerHTML='<div class="alert alert-error">Error: '+error.message+'</div>';return;}

  // Actualizar saldo alumno
  alumno.total_abonado=(alumno.total_abonado||0)+montoTotal;
  alumno.fecha_ultimo_pago=fecha;
  await db.from('alumnos').update({total_abonado:alumno.total_abonado,fecha_ultimo_pago:fecha}).eq('id',alumno.id);
  ALL.find(a=>a.id===alumno.id).total_abonado=alumno.total_abonado;
  ALL.find(a=>a.id===alumno.id).fecha_ultimo_pago=fecha;

  alertEl.innerHTML='<div class="alert alert-success">Pago agregado correctamente.</div>';
  setTimeout(()=>alertEl.innerHTML='',2500);
  actualizarMetricas();filtrar();renderAlertas();
  renderMPagos();
}

async function editarPago(pagoId){
  const alertEl=document.getElementById('modal-alert');
  const fecha=document.getElementById('pf-fecha-'+pagoId).value;
  const monto=parseFloat(document.getElementById('pf-monto-'+pagoId).value)||0;
  const metodo=document.getElementById('pf-metodo-'+pagoId).value;
  const cuota=parseInt(document.getElementById('pf-cuota-'+pagoId).value)||null;
  const quien=document.getElementById('pf-quien-'+pagoId).value;
  const notas=document.getElementById('pf-notas-'+pagoId).value;

  const {error}=await db.from('pagos').update({fecha,monto,metodo,cuota,quien_recibio:quien||null,notas:notas||null}).eq('id',pagoId);
  if(error){alertEl.innerHTML='<div class="alert alert-error">Error: '+error.message+'</div>';return;}

  // Recalcular total abonado
  const {data:pagos}=await db.from('pagos').select('monto,fecha').eq('alumno_id',alumno.id).order('fecha',{ascending:false});
  if(pagos){
    const total=pagos.reduce((s,p)=>s+(p.monto||0),0);
    const ultima=pagos[0]?.fecha||null;
    alumno.total_abonado=total;
    alumno.fecha_ultimo_pago=ultima;
    await db.from('alumnos').update({total_abonado:total,fecha_ultimo_pago:ultima}).eq('id',alumno.id);
    const al=ALL.find(a=>a.id===alumno.id);
    if(al){al.total_abonado=total;al.fecha_ultimo_pago=ultima;}
  }

  alertEl.innerHTML='<div class="alert alert-success">Pago actualizado.</div>';
  setTimeout(()=>alertEl.innerHTML='',2000);
  actualizarMetricas();filtrar();renderAlertas();
  renderMPagos();
}

async function eliminarPago(pagoId,monto){
  if(!confirm('¿Eliminar este pago de '+usd2(monto)+'? Esta acción no se puede deshacer.'))return;
  const alertEl=document.getElementById('modal-alert');
  const {error}=await db.from('pagos').delete().eq('id',pagoId);
  if(error){alertEl.innerHTML='<div class="alert alert-error">Error: '+error.message+'</div>';return;}

  // Recalcular
  const {data:pagos}=await db.from('pagos').select('monto,fecha').eq('alumno_id',alumno.id).order('fecha',{ascending:false});
  const total=pagos?pagos.reduce((s,p)=>s+(p.monto||0),0):0;
  const ultima=pagos&&pagos.length?pagos[0].fecha:null;
  alumno.total_abonado=total;alumno.fecha_ultimo_pago=ultima;
  await db.from('alumnos').update({total_abonado:total,fecha_ultimo_pago:ultima}).eq('id',alumno.id);
  const al=ALL.find(a=>a.id===alumno.id);
  if(al){al.total_abonado=total;al.fecha_ultimo_pago=ultima;}

  alertEl.innerHTML='<div class="alert alert-success">Pago eliminado.</div>';
  setTimeout(()=>alertEl.innerHTML='',2000);
  actualizarMetricas();filtrar();renderAlertas();
  renderMPagos();
}

