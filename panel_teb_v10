  const {data}=await db.from('alumnos').select('*,ediciones(nombre)').eq('es_ex_teb',true).order('nombre');
  const lista=data||[];
  if(!lista.length){document.getElementById('tabla-ex-teb').innerHTML='<div class="loading">No hay ex alumnos registrados todavía.</div>';return;}
  let h='<div style="overflow-x:auto"><table><thead><tr><th>Nombre</th><th>Programa</th><th>Edición</th><th>Plan</th><th>% Cobrado</th><th>Acción</th></tr></thead><tbody>';
  lista.forEach(a=>{
    h+='<tr><td style="font-weight:500">'+a.nombre+'</td>';
    h+='<td>'+pProg(a.programa)+'</td>';
    h+='<td><span class="pill pill-gray">'+(a.ediciones?a.ediciones.nombre:'—')+'</span></td>';
    h+='<td>'+pPlan(a.plan)+'</td>';
    h+='<td>'+bar(a.total_abonado,a.total_a_pagar)+'</td>';
    h+='<td><button class="btn btn-sm" onclick="moverDeExTeb(\''+a.id+'\')">↩ Restaurar</button></td></tr>';
  });
  h+='</tbody></table></div><div style="padding:8px 14px;font-size:12px;color:#888;border-top:0.5px solid #f0f0e8">'+lista.length+' ex alumnos</div>';
  document.getElementById('tabla-ex-teb').innerHTML=h;
}

async function moverAExTeb(id){
  if(!confirm('¿Mover este alumno a Ex TEB? Ya no aparecerá en la lista principal.'))return;
  await db.from('alumnos').update({es_ex_teb:true}).eq('id',id);
  ALL=ALL.filter(a=>a.id!==id);
  actualizarMetricas();filtrar();renderAlertas();renderAlertasVisa();
  cerrarModal();
  document.getElementById('alert-global').innerHTML='<div class="alert alert-success">Alumno movido a Ex TEB.</div>';
  setTimeout(()=>document.getElementById('alert-global').innerHTML='',3000);
}

async function moverDeExTeb(id){
  await db.from('alumnos').update({es_ex_teb:false}).eq('id',id);
  renderExTeb();
}

function mostrarTab(tab){
  ['alumnos','dashboard','alertas','alertas-visa','ex-teb','cuenta'].forEach(t=>{
    const el=document.getElementById('sec-'+t);
    if(el)el.style.display=t===tab?'block':'none';
  });
  document.querySelectorAll('.tab').forEach((b,i)=>b.classList.toggle('active',['alumnos','dashboard','alertas','alertas-visa','ex-teb','cuenta'][i]===tab));
  if(tab==='dashboard')renderDashboard();
  if(tab==='alertas-visa')renderAlertasVisa();
  if(tab==='ex-teb')renderExTeb();
}
document.getElementById('modal-alumno').addEventListener('click',function(e){if(e.target===this)cerrarModal();});
init();
</script>
