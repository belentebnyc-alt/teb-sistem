<script>
const SURL='https://sjlaccqognqxubjeweah.supabase.co';
const SKEY='sb_publishable_C5hjAFL3IHUfkbS-sug89g_Hu3MjmDP';
const {createClient}=supabase;
const db=createClient(SURL,SKEY);

let ALL=[],EDS=[],alumno=null,tabM='perfil',pagoEditando=null;
const HOY=new Date();

function diasDesde(f){if(!f)return null;return Math.floor((HOY-new Date(f))/(864e5));}
function usd(n){return 'USD '+(Math.round(n||0)).toLocaleString('es-AR');}
function usd2(n){return 'USD '+Number(n||0).toLocaleString('es-AR',{minimumFractionDigits:2,maximumFractionDigits:2});}
function pVisa(v){const m={'SI':'green','NO':'red','En tramite':'amber','Rechazada':'red'};return '<span class="pill pill-'+(m[v]||'gray')+'">'+(v||'NO')+'</span>';}
function pProg(p){const m={'Teatro Musical':'purple','Bailarin':'blue','Cantante':'amber','Musico':'green'};return '<span class="pill pill-'+(m[p]||'gray')+'">'+(p||'—')+'</span>';}
function pPlan(p){const m={'Economy':'gray','Comfort':'blue','Comfort +':'purple','NO HOTEL':'amber'};return '<span class="pill pill-'+(m[p]||'gray')+'">'+(p||'—')+'</span>';}
function pEstado(e){
  const m={'Activo':'🟢','Pausado':'🟡','No responde':'🔴','Reembolso solicitado':'🟠','Baja':'⚫'};
  const c={'Activo':'green','Pausado':'amber','No responde':'red','Reembolso solicitado':'amber','Baja':'gray'};
  return '<span class="pill pill-'+(c[e]||'gray')+'">'+(m[e]||'●')+' '+(e||'—')+'</span>';
}
function estadoFinanciero(abonado, total, diasUltimoPago){
  if(!total||total<=0)return '<span class="pill pill-gray">Sin info</span>';
  if(abonado>=total)return '<span class="pill pill-green">✓ Pagado</span>';
  if(diasUltimoPago===null)return '<span class="pill pill-gray">Sin pagos</span>';
  if(diasUltimoPago<=30)return '<span class="pill pill-green">Al día</span>';
  if(diasUltimoPago<=35)return '<span class="pill pill-amber">Pendiente</span>';
  if(diasUltimoPago<=55)return '<span class="pill pill-amber" style="background:#FAEEDA;color:#854F0B">Atrasado</span>';
  if(diasUltimoPago<=60)return '<span class="pill pill-red">Moroso</span>';
  return '<span class="pill pill-red" style="background:#791F1F;color:white">Vacante liberada</span>';
}
function bar(ab,tot,w){
  if(!tot)return '—';
  const pct=Math.min(100,Math.round((ab/tot)*100));
  const c=pct>=80?'#27500A':pct>=50?'#004225':'#791F1F';
  return '<div class="progress"><div class="progress-bar" style="width:'+(w||70)+'px"><div class="progress-fill" style="width:'+pct+'%;background:'+c+'"></div></div><span style="font-size:11px;color:#666">'+pct+'%</span></div>';
}
function diasBadge(d){
  if(d===null)return '<span style="color:#aaa;font-size:11px">Sin pagos</span>';
  if(d<=0)return '<span class="dias-ok">Hoy</span>';
  if(d<=30)return '<span class="dias-ok">Hace '+d+'d</span>';
  if(d<=60)return '<span class="dias-warn">⚠ '+d+'d</span>';
  return '<span class="dias-danger">🔴 '+d+'d moroso</span>';
}
function rowClass(d){if(d===null||d<=30)return '';if(d<=60)return 'row-warn';return 'row-danger';}
function metodoColor(m){const map={'Stripe':'blue','Transferencia':'green','BOFA':'purple','MercadoPago':'amber','Efectivo':'gray','Otro':'gray'};return map[m]||'gray';}

async function init(){
  document.querySelector('.topbar h1').textContent='TEB — Panel · '+new Date().toLocaleDateString('es-AR');
  const {data:eds}=await db.from('ediciones').select('*').order('fecha_inicio');
  EDS=eds||[];
  const sel=document.getElementById('filtro-edicion');
  EDS.forEach(e=>{const o=document.createElement('option');o.value=e.id;o.textContent=e.nombre;sel.appendChild(o);});
  const {data:al}=await db.from('alumnos').select('*,ediciones(nombre,id)').eq('es_ex_teb',false).order('nombre');
  ALL=al||[];
  actualizarMetricas();renderAlumnos(ALL);renderAlertas();
}

function actualizarMetricas(){
  const cobrado=ALL.reduce((s,a)=>s+(a.total_abonado||0),0);
  const pendiente=ALL.reduce((s,a)=>s+(a.total_a_pagar||0)-(a.total_abonado||0),0);
